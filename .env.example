GROQ_API_KEY=your_groq_key_here

# LLM slot configuration: provider/model
# GATEKEEPER_LLM=groq/llama-3.1-8b-instant
# AGENT_LLM=groq/openai/gpt-oss-120b
# UTILITY_LLM=groq/llama-3.3-70b-versatile

# Optional: needed only if using openrouter provider
# OPENROUTER_API_KEY=
# TUSK_TOOL_USAGE_FILE=.tusk_runtime/tool_usage.json

# Audio settings
# WHISPER_MODEL_SIZE=base
# VAD_AGGRESSIVENESS=2
# AUDIO_SAMPLE_RATE=16000
# AUDIO_FRAME_DURATION_MS=30
